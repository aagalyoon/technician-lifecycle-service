# Database
DATABASE_URL=postgresql://postgres:postgres@db:5432/techlifecycle
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=techlifecycle
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ServiceTitan Mock API
SERVICETITAN_API_URL=http://mock-servicetitan:3001
SERVICETITAN_CLIENT_ID=mock-client-id
SERVICETITAN_CLIENT_SECRET=mock-client-secret

# Sync Configuration
SYNC_INTERVAL_MINUTES=15
SYNC_BATCH_SIZE=100

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info
